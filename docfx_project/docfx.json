{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "files": [
            "src/Wolfgang.Extensions.String/Wolfgang.Extensions.String.csproj"
          ],
          "src": "../"
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net10.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "logo.svg",
          "apple-touch-icon.png",
          "favicon.svg",
          "favicon.ico",
          "images/**",
          "public/**",
          "versions.json"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "modern",
      "default"
    ],
    "globalMetadata": {
      "_appName": "Wolfgang.Extensions.String",
      "_appTitle": "Wolfgang.Extensions.String",
      "_appLogoPath": "logo.svg",
      "_appFaviconPath": "favicon.svg",
      "_enableSearch": true,
      "_appFooter": "Made with DocFX <script>(function(){var r='/';if(window.location.hostname.endsWith('.github.io')){var s=window.location.pathname.split('/').filter(Boolean);if(s.length)r='/'+s[0]+'/';}var t=document.createElement('script');t.src=r+'public/version-picker.js';t.async=true;document.head.appendChild(t);})();</script>",
      "pdf": true
    }
  }
}
